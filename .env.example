# ---------- Base de datos ----------
# Producción: URL que te da Railway al crear el addon de PostgreSQL
# (tab "Variables" → DATABASE_URL). Ejemplo:
#   DATABASE_URL="postgresql://postgres:PASS@containers-us-west-123.railway.app:6543/railway"
#
# Dev local: podés usar la MISMA Railway DB (más simple) o montar un
# Postgres local (Docker). El schema ya está configurado para PostgreSQL.
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naturalpack"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naturalpack"

# ---------- Auth ----------
# Generá uno random largo, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# ---------- Kiosk ----------
# Token simple para autorizar lectores QR legacy (hardware reader en la puerta).
ACCESS_READER_TOKEN="reader-local-token"

# URL pública que el QR del kiosk va a embeber. En Vercel seteá esto con la
# URL de tu deploy (ej. https://naturalpack.vercel.app) para que el QR apunte
# al dominio correcto desde el celular del socio.
# En dev podés dejarlo vacío: el server autodetecta la IP LAN (192.168.x.x).
# PUBLIC_BASE_URL="https://naturalpack.vercel.app"

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="NaturalPack"
